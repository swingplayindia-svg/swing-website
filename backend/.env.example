# --- Email (pick ONE provider) ---

# RECOMMENDED for Railway — Resend uses HTTPS (SMTP ports are blocked on Railway)
# Get API key: https://resend.com/api-keys
# Verify your domain in Resend, then use e.g. SWING <noreply@yourdomain.com>
RESEND_API_KEY=
RESEND_FROM_EMAIL=SWING <noreply@swing-play.com>

# Optional — where admin notifications go + reply-to for user emails
MAIL_TO=swingplay.india@gmail.com

# LOCAL DEV ONLY — Gmail SMTP (does not work on Railway)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=swingplay.india@gmail.com
SMTP_PASS=your-app-password-here
MAIL_FROM=swingplay.india@gmail.com

# Firebase Admin — same service account as swing-play-admin-cms
FIREBASE_PROJECT_ID=swing-b7a0c
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173,https://your-website-domain.com
