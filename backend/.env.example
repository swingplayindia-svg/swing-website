# Gmail SMTP (requires a Google App Password — not your regular password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=swingplay.india@gmail.com
SMTP_PASS=your-app-password-here

# Outgoing + admin notification address
MAIL_FROM=swingplay.india@gmail.com
MAIL_TO=swingplay.india@gmail.com

# Firebase Admin — same service account as swing-play-admin-cms
# Option A: paste full service account JSON on one line
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: individual fields
FIREBASE_PROJECT_ID=swing-b7a0c
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173,https://your-website-domain.com
