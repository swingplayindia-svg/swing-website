# Nodemailer + Gmail SMTP
# App password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=swingplay.india@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=swingplay.india@gmail.com
MAIL_TO=swingplay.india@gmail.com

# Firebase Admin — same service account as swing-play-admin-cms
FIREBASE_PROJECT_ID=swing-b7a0c
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

PORT=3001
CORS_ORIGIN=http://localhost:5173,https://your-website-domain.com

# Railway blocks outbound SMTP (587/465). Use Fly.io or a VPS for nodemailer + Gmail.
# Same Dockerfile works: fly launch --path backend
